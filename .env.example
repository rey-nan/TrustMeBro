# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# LLM Provider (openrouter | ollama | groq | gemini | openai)
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=
LLM_DEFAULT_MODEL=

# Security
API_SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:5173

# Storage
DB_PATH=./data/trustmebro.db

# Sandbox
SANDBOX_TYPE=docker           # docker | local
SANDBOX_DOCKER_IMAGE=node:20-alpine
SANDBOX_TIMEOUT_MS=30000
SANDBOX_MAX_MEMORY=256m
SANDBOX_MAX_CPU=0.5
